{
  "name": "@hg-argo/demo-game-lib",
  "version": "1.0.0",
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "typedocOptions": {
    "entryPoints": [
      "src/index.ts"
    ],
    "tsconfig": "./tsconfig.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:publint": "publint",
    "check:attw": "attw --pack .",
    "demo": "tsx src/demo.ts"
  },
  "dependencies": {
    "@hg-argo/demo-core-lib": "1.0.0"
  }
}
